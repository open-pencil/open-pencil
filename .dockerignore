# flyctl launch added from .gitignore
# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/lerna-debug.log*

**/node_modules
**/dist
**/dist-ssr
**/*.local
# Tauri updater private signing keys
desktop/*.key
!desktop/*.key.pub

# Copied from node_modules at build time
**/public/canvaskit.wasm
**/public/canvaskit-webgpu

# Editor directories and files
**/.vscode/*
!**/.vscode/extensions.json
**/.idea
**/.DS_Store
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
**/test-results
# Git worktrees for parallel agent work
**/.worktrees
# すべての .env* を ignore してから *.example / *.template / .envrc だけ復帰させる
# (.env.staging / .env.test / .env.preview / packages/api/.env.* 等の派生 mode に対しても
# live secret 流出を防ぐため、 必ず明示 example 経路に限定する)
# .envrc (direnv policy) と .env*.template (説明用テンプレ) は秘密を含まない想定で track 許可
**/.env*
!**/.env*.example
!**/**/.env*.example
!**/.env*.template
!**/**/.env*.template
!**/.envrc
!**/**/.envrc
**/**/.context
**/packages/docs/.vitepress/cache
**/packages/docs/.vitepress/dist
**/docs/.vitepress/cache
**/docs/.vitepress/dist
**/packages/collab/.wrangler
**/packages/core/vendor/canvaskit-webgpu
**/patches/skia-webgpu
**/.wrangler

**/Caddyfile.dev
**/components.d.ts
**/vue-stream-markdown

# Agent scratch space (reviews, test artifacts)
**/scratch

# Local verification artifacts (scripts/)
**/scripts/*.svg
**/scripts/*.html
**/scripts/*.png
**/scripts/debug-*.ts
**/scripts/export-svg.ts
**/scripts/render-to-svg.ts
**/scripts/test-pen-render.ts

# flyctl launch added from desktop/.gitignore
# Generated by Cargo
# will have compiled files and executables
desktop/target

# Generated by Tauri
# will have schema files for capabilities auto-completion
desktop/gen/schemas
fly.toml
