# Pencil Editor — ローカル開発用環境変数テンプレート
#
# 使い方:
#   cp .env.local.example .env.local
#   bun run dev:full
#
# 本番では絶対にこの値を使わない (ダミー dev 値)。

# === API server (port 3001) ===

# Better Auth 用 secret (32 文字以上必須)
INKLY_API_AUTH_SECRET=dev-only-auth-secret-min-32-chars-please-replace

# JWT 用 secret (32 文字以上必須)
INKLY_API_JWT_SECRET=dev-only-jwt-secret-min-32-chars-please-replace

# === DB ===
# ローカル: SQLite file (.context/api-data/inkly.db に永続化)
# テスト: INKLY_API_DB_MODE=memory で in-memory
# 本番: TURSO_DATABASE_URL を設定すると Turso (libSQL remote) に自動切替
#
# 優先順位:
#   1. TURSO_DATABASE_URL があれば remote (Turso)
#   2. INKLY_API_DB_MODE=memory なら in-memory
#   3. それ以外は file mode

# (テスト用) INKLY_API_DB_MODE=memory
# (本番用) TURSO_DATABASE_URL=libsql://your-db.turso.io
# (本番用) TURSO_AUTH_TOKEN=eyJ...

# === Google OAuth ===
# 本物の Google ログインを試す場合のみ設定
# GCP Console (https://console.cloud.google.com) で OAuth 2.0 Client ID を作成し、
# 承認済みリダイレクト URI に http://localhost:3001/api/auth/callback/google を追加。
# 未設定なら Google ログインボタンは "Google login is not configured" を返す。
# INKLY_API_GOOGLE_CLIENT_ID=
# INKLY_API_GOOGLE_CLIENT_SECRET=

# === Resend メール送信 ===
# 招待メールを実際に送る場合のみ設定 (未設定は no-op、 開発で困らない)
# INKLY_API_RESEND_KEY=
