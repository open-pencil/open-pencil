# Pencil Editor — Playwright e2e 用環境変数
#
# 使い方:
#   cp .env.e2e.example .env.e2e
#   bun run test  (playwright が起動する API server に渡される)
#
# DB は in-memory (test ごとにリセット)。

INKLY_API_AUTH_SECRET=e2e-only-auth-secret-min-32-chars-padding-here
INKLY_API_JWT_SECRET=e2e-only-jwt-secret-min-32-chars-padding-here
INKLY_API_DB_MODE=memory
