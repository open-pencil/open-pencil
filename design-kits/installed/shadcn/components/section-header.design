{
  "version": "0.1.0",
  "meta": { "name": "SectionHeader", "generator": "verso-kit/1.0.0" },
  "variables": {
    "section.fg": { "type": "color", "value": "#FAFAFA" },
    "section.muted": { "type": "color", "value": "#A1A1AA" },
    "section.badge.bg": { "type": "color", "value": "#27272A" },
    "section.badge.fg": { "type": "color", "value": "#FAFAFA" }
  },
  "children": [
    {
      "id": "section-header-with-badge",
      "name": "SectionHeader / With Badge",
      "type": "frame",
      "reusable": true,
      "width": 640,
      "height": "fit_content",
      "layout": "vertical",
      "alignItems": "center",
      "gap": 16,
      "children": [
        {
          "id": "section-badge",
          "name": "Badge",
          "type": "frame",
          "width": "fit_content",
