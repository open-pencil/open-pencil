# Pencil Editor — production 環境変数 (Fly.io secrets 用)
#
# 使い方:
#   cp .env.prod.example .env.prod
#   .env.prod を編集して実値を入れる
#   bash scripts/deploy.sh
#
# 機密情報を含むため .env.prod は git にコミットしない (.gitignore で除外済み)。
# 値の取得方法は DEPLOY-NOW.md / DEPLOY.md を参照。

# === Auth (必須) ===
# 32 byte hex で生成: openssl rand -hex 32
INKLY_API_AUTH_SECRET=
INKLY_API_JWT_SECRET=

# === Database / Turso (必須) ===
# 既存 DB の URL: libsql://pencil-editor-jfet-cardene.aws-ap-northeast-1.turso.io
# token は turso db tokens create pencil-editor で再発行
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Email / Resend (任意) ===
# 未設定なら Dry-run mode (console.log のみ、 実際にメール送信されない)
# 取得: https://resend.com → API Keys → Create
INKLY_API_RESEND_KEY=

# === Google OAuth (任意) ===
# 未設定なら email/password ログインのみ
# 取得: https://console.cloud.google.com/apis/credentials
# Redirect URI: https://pencil-editor.fly.dev/api/auth/callback/google
INKLY_API_GOOGLE_CLIENT_ID=
INKLY_API_GOOGLE_CLIENT_SECRET=
