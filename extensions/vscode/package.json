{
  "name": "open-pencil-vscode",
  "displayName": "OpenPencil",
  "description": "Browse .fig design files in VS Code",
  "version": "0.1.0",
  "publisher": "dannote",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCustomEditor:openPencil.figEditor",
    "workspaceContains:**/*.fig"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "openPencil.figEditor",
        "displayName": "OpenPencil Design",
        "selector": [
          { "filenamePattern": "*.fig" }
        ],
        "priority": "default"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openPencil",
          "title": "OpenPencil",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "openPencil": [
        {
          "id": "openPencil.pages",
          "name": "Pages",
          "type": "tree"
        },
        {
          "id": "openPencil.components",
          "name": "Components",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "openPencil.openFile",
        "title": "Open .fig File",
        "category": "OpenPencil"
      },
      {
        "command": "openPencil.copyCSS",
        "title": "Copy CSS",
        "category": "OpenPencil"
      },
      {
        "command": "openPencil.inspect",
        "title": "Inspect Element",
        "category": "OpenPencil"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "openPencil.copyCSS",
          "when": "viewItem == openPencilComponent",
          "group": "inline"
        },
        {
          "command": "openPencil.inspect",
          "when": "viewItem == openPencilComponent",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "OpenPencil",
      "properties": {
        "openPencil.autoDetectFigFiles": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect .fig files in workspace"
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "openPencil.pages",
        "contents": "No .fig file is open.\n[Open .fig File](command:openPencil.openFile)"
      },
      {
        "view": "openPencil.components",
        "contents": "No .fig file is open.\n[Open .fig File](command:openPencil.openFile)"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "canvaskit-wasm": "^0.40.0",
    "culori": "^4.0.2",
    "fflate": "^0.8.2",
    "fzstd": "^0.1.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.0"
  }
}
