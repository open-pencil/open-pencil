{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
    "types": ["bun"],
    "paths": {
      "@open-pencil/common": ["./src/index.ts"],
      "@open-pencil/common/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
