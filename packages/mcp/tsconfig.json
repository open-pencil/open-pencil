{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "#mcp/*": ["./src/*"]
    },
    "noCheck": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/server.ts", "src/stdio.ts"]
}
