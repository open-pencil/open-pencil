# Pencil Editor — production 環境変数 (Fly.io secrets で注入する想定)
#
# このファイルは secret 配布用ではない。 必要な変数の一覧を示すだけ。
# 本番では `fly secrets set KEY=...` でそれぞれ注入する (template を repo に commit しない)。
#
# 使い方:
#   fly secrets set \
#     INKLY_API_AUTH_SECRET=$(openssl rand -hex 32) \
#     INKLY_API_JWT_SECRET=$(openssl rand -hex 32) \
#     TURSO_DATABASE_URL=libsql://your-db.turso.io \
#     TURSO_AUTH_TOKEN=eyJ...
#
# DB は Turso (libSQL remote) に接続。

INKLY_API_AUTH_SECRET=
INKLY_API_JWT_SECRET=
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
