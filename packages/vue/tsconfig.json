{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "rootDir": "..",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "#vue/*": ["./src/*", "./src/*.vue"],
      "#core/*": ["../core/src/*"],
      "@open-pencil/vue": ["./src/index.ts"],
      "@open-pencil/core": ["../core/src/index.ts"],
      "@open-pencil/core/*": ["../core/src/*"],
      "@open-pencil/core/editor": ["../core/src/editor/index.ts"],
      "@open-pencil/core/render": ["../core/src/render/index.ts"],
      "@open-pencil/core/color": ["../core/src/color.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/**/*.d.ts", "../core/src/global.d.ts"],
  "exclude": ["node_modules", "dist", "example"]
}
