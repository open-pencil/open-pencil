          "children": [
            {
              "id": "glowing-card-default-title",
              "name": "Title",
              "type": "text",
              "content": "Premium Feature",
              "fontSize": 20,
              "fontWeight": 600,
              "fill": "$card.fg"
            },
            {
              "id": "glowing-card-default-desc",
