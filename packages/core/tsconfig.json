{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowArbitraryExtensions": true,
    "types": ["node", "bun"],

    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "#core/*": ["./src/*"],
      "@inkly/core": ["./src/index.ts"],
      "@inkly/core/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
