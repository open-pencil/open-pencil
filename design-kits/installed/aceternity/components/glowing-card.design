{
  "version": "0.1.0",
  "meta": { "name": "GlowingCard", "generator": "verso-kit/1.0.0" },
  "variables": {
    "glow.primary": { "type": "color", "value": "#6366F1" },
    "glow.secondary": { "type": "color", "value": "#8B5CF6" },
    "glow.blue": { "type": "color", "value": "#3B82F6" },
    "glow.accent": { "type": "color", "value": "#EC4899" },
    "card.bg": { "type": "color", "value": "#111118" },
    "card.fg": { "type": "color", "value": "#FAFAFA" },
