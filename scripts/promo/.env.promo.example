# 動画生成用 ローカル env (cp して .env.promo にする、 git 管理外で OK)
# このファイルは scripts/promo/build.sh が必要とする最小セット。
# 機密値は含めず、 in-memory DB の promo 専用 fixed 値だけを置く。
# 本番値が必要な variable は無い (production の Google ログインは一切使わない)。

# better-auth セッション暗号化用 secret (32 文字、 promo 専用なので公開固定値で OK)
INKLY_API_AUTH_SECRET=promo-only-auth-secret-32chars-fixed-for-local

# JWT signing secret (32 文字、 promo 専用なので公開固定値で OK)
INKLY_API_JWT_SECRET=promo-only-jwt-secret-32chars-fixed-for-local

# Google OAuth client 情報 (promo は test/login 経由なので空で OK)
INKLY_API_GOOGLE_CLIENT_ID=
INKLY_API_GOOGLE_CLIENT_SECRET=

# Resend メール API (promo は招待メール送信を行わないので空で OK)
INKLY_API_RESEND_KEY=

# Turso (libSQL リモート) — promo は in-memory DB のため空で OK
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# test/login エンドポイントを有効化 (promo 専用、 本番では必ず無効)
INKLY_API_AUTH_ENABLE_TEST_UTILS=1

# 毎回クリーンな DB で起動するため in-memory モード
INKLY_API_DB_MODE=memory
