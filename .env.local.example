# Pencil Editor — ローカル開発用環境変数
#
# 使い方:
#   cp .env.local.example .env.local
#   bun run dev:full
#
# DB はローカル SQLite ファイル (.context/api-data/inkly.db) に永続化。
# Google OAuth や Resend を使いたい場合は README の該当 section を参照。

INKLY_API_AUTH_SECRET=dev-only-auth-secret-min-32-chars-please-replace
INKLY_API_JWT_SECRET=dev-only-jwt-secret-min-32-chars-please-replace
