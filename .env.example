# Local-only cloud storage prefill (copy to .env.local — never commit secrets).
# Vite only exposes vars prefixed with VITE_ to the web app.
# Prefill runs once when the matching localStorage field is empty.

# VITE_OPENPENCIL_CLOUD_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# VITE_OPENPENCIL_CLOUD_S3_BUCKET=OpenPencil-DEV
# VITE_OPENPENCIL_CLOUD_S3_ACCESS_KEY_ID=
# VITE_OPENPENCIL_CLOUD_S3_SECRET_ACCESS_KEY=
# Region is inferred from the endpoint (no separate field).
